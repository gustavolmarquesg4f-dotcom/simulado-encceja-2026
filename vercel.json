{
  "redirects": [
    { "source": "/", "destination": "/englishos/", "permanent": false },
    { "source": "/englishos", "destination": "/englishos/", "permanent": false }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/englishos/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(self)" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}
